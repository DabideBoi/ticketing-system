# Copy to .env and fill in real values. Never commit the real .env file.

# Postgres (used by docker-compose.yml and the backend's `prod` profile)
DB_NAME=ticketing
DB_USERNAME=ticketing
DB_PASSWORD=ticketing
DB_URL=jdbc:postgresql://localhost:5432/ticketing

# Backend
JWT_SECRET=change-me-to-a-long-random-string
N8N_WEBHOOK_URL=https://your-n8n-instance/webhook/your-webhook-id
